{
  "version": 2,
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "main.py"
    }
  ],
  "crons": [
    {
      "path": "/statpitch/predictions/check-results",
      "schedule": "0 * * * *"
    },
    {
      "path": "/statpitch/predictions/sync-tomorrow",
      "schedule": "0 6 * * *"
    }
  ]
}